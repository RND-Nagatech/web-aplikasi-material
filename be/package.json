{
  "name": "admin-dashboard-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready backend API for web admin dashboard",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "db:backfill:created-date-ts": "ts-node src/scripts/backfill-created-date-ts.ts",
    "db:backfill:cash-daily": "ts-node src/scripts/backfill-cash-daily.ts",
    "db:migrate:is-active-semantics": "ts-node src/scripts/migrate-is-active-semantics.ts",
    "db:sync-indexes": "ts-node src/scripts/sync-indexes.ts",
    "quality:check-indexes": "ts-node src/scripts/check-duplicate-indexes.ts",
    "quality:gate": "npm run typecheck && npm run build && npm run quality:check-indexes"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
